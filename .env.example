# HubSpot Private App token. Required scopes: tickets + sales-email-read.
HUBSPOT_ACCESS_TOKEN=

# Microsoft 365 IMAP connection
IMAP_HOST=outlook.office365.com
IMAP_PORT=993
IMAP_MAILBOX=INBOX
IMAP_USER=

# Use "password" only for a connectivity test. Exchange Online normally requires OAuth2.
IMAP_AUTH_MODE=password
IMAP_PASSWORD=
IMAP_ACCESS_TOKEN=

# Matching tolerance for the metadata fallback.
MATCH_WINDOW_MINUTES=2

